# Copy to .env and fill in — .env is gitignored, never commit real values.

# GitHub token with read access to APP_REPO/AUTOMATION_REPO and write
# access to DOCS_REPO. Used as the fallback for all three unless
# --app-token/--automation-token/--docs-token are passed explicitly to
# the orchestrator.
GITHUB_TOKEN=

# doc-generator's LLM provider: "dummy" (default, no credentials needed,
# produces a deterministic draft) or "bedrock" (real Claude via AWS
# Bedrock).
LLM_PROVIDER=dummy

# Required when LLM_PROVIDER=bedrock. No default is guessed — get the
# exact model ID (or inference profile ARN) from the Bedrock console.
BEDROCK_MODEL_ID=
AWS_REGION=us-east-1

# Bedrock API key (bearer token) — the simplified Bedrock-specific auth
# option. See src/doc-generator/bedrockLlmClient.ts for how this is
# resolved automatically by the AWS SDK.
AWS_BEARER_TOKEN_BEDROCK=

# Alternative to AWS_BEARER_TOKEN_BEDROCK: standard IAM credentials.
# Not needed if using the bearer token above, or if running somewhere
# with an IAM role already attached (EC2 instance role, etc.).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
