{
  "name": "release-doc-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Internal tool that generates product-readable release documents from code diffs and automation test coverage",
  "type": "commonjs",
  "scripts": {
    "scan:code": "tsx src/code-scanner/index.ts",
    "scan:test": "tsx src/test-scanner/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
