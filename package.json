{
  "name": "release-doc-generator",
  "version": "0.1.0",
  "private": true,
  "description": "Internal tool that generates product-readable release documents from code diffs and automation test coverage",
  "type": "commonjs",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "release-doc-generate": "dist/orchestrator/index.js",
    "release-doc-scan-code": "dist/code-scanner/index.js",
    "release-doc-scan-tests": "dist/test-scanner/index.js",
    "release-doc-map": "dist/mapping-engine/index.js",
    "release-doc-draft": "dist/doc-generator/index.js"
  },
  "scripts": {
    "scan:code": "tsx src/code-scanner/index.ts",
    "scan:test": "tsx src/test-scanner/index.ts",
    "map": "tsx src/mapping-engine/index.ts",
    "draft": "tsx src/doc-generator/index.ts",
    "generate": "tsx src/orchestrator/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1087.0",
    "@octokit/rest": "^21.0.2",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
